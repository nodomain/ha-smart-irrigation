###############################################################################
# Smart Irrigation — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These values are substituted into the *.tpl templates by deploy.sh.
###############################################################################

# --- Zone 1 ---
ZONE1_SWITCH="switch.your_zone_1_switch_entity"
ZONE1_NAME="Zone 1"

# --- Zone 2 ---
ZONE2_SWITCH="switch.your_zone_2_switch_entity"
ZONE2_NAME="Zone 2"

# --- Zone 3 ---
ZONE3_SWITCH="switch.your_zone_3_switch_entity"
ZONE3_NAME="Zone 3"

# --- Zone 4 ---
ZONE4_SWITCH="switch.your_zone_4_switch_entity"
ZONE4_NAME="Zone 4"

# --- Soil moisture sensors (Ecowitt) ---
ZONE1_SENSOR="sensor.your_zone_1_soil_moisture"
ZONE2_SENSOR="sensor.your_zone_2_soil_moisture"
ZONE3_SENSOR="sensor.your_zone_3_soil_moisture"
ZONE4_SENSOR="sensor.your_zone_4_soil_moisture"

# --- Notifications ---
IPHONE_DEVICE="your_iphone"

# --- Device monitoring (battery + connection sensors) ---
ZONE1_DEVICE_ID="your_terrasse_device_id"
ZONE4_DEVICE_ID="your_hochbeet_device_id"
GATEWAY_CONNECTION_ENTITY="binary_sensor.your_gateway_connection_entity"
ZONE1_CONNECTION_ENTITY="binary_sensor.your_terrasse_connection_entity"
ZONE4_CONNECTION_ENTITY="binary_sensor.your_hochbeet_connection_entity"

# --- HA connectivity (optional — enables deploy.sh auto-mount & API push) ---
HA_CONFIG_MOUNT="/Volumes/config"
HA_CONFIG_SMB_URL=""
HA_URL=""
HA_TOKEN=""
HA_DASHBOARD_URL_PATH="smart-irrigation"
